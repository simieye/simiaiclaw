# SIMIAICLAW 龙虾集群太极64卦系统 - 环境变量模板
# 复制此文件为 .env 并填入真实值

# ===== AI 模型配置 =====
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===== LLM 模型偏好（可选，默认自动路由）=====
LLM_PRIMARY_MODEL=claude-sonnet-4-20251120
LLM_FALLBACK_MODEL=gpt-4o

# ===== 多租户认证配置 =====
JWT_SECRET=change-this-to-a-long-random-secret-in-production
EXPRESS_SESSION_SECRET=same-as-above-recommended-32chars-minimum

# ===== ClawTip 支付配置 =====
CLAWTIP_API_KEY=your_clawtip_api_key_here
CLAWTIP_WALLET_ID=your_wallet_id_here
CLAWTIP_SMALL_THRESHOLD=500
CLAWTIP_MEDIUM_THRESHOLD=5000

# ===== Stripe 支付（国际）=====
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===== 微信支付（国内）=====
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_key
WECHAT_APP_ID=your_app_id
WECHAT_NOTIFY_URL=https://your-domain.com/api/payments/wechat/callback

# ===== 支付宝（国内）=====
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# ===== Dageno GEO/AEO 配置 =====
DAGEN0_API_KEY=your_dageno_api_key_here

# ===== HeyGen LiveAvatar 实时数字人配置 =====
# LiveAvatar API Key（从 app.liveavatar.com/developers 获取）
# 用于实时 WebRTC 数字人流（费用: FULL模式 2积分/分钟, LITE模式 1积分/分钟）
HEYGEN_LIVEAVATAR_API_KEY=your_liveavatar_api_key_here

# HeyGen Video Agent API Key（从 developers.heygen.com 获取）
# 用于文本转视频生成
HEYGEN_API_KEY=your_heygen_api_key_here

# ===== Gemini 文案+生图配置 =====
# Gemini API Key（从 ai.google.dev/apikey 获取，免费额度充足）
GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI 配置（用于 Imagen 3 图像生成，需 Google Cloud）
# Google Cloud 项目 ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id
# Google Cloud 区域
GOOGLE_CLOUD_LOCATION=us-central1
# Service Account JSON 密钥（从 Google Cloud Console 下载）
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# ===== NotebookLM 知识库配置 =====
# Enterprise 模式：使用 Google Cloud NotebookLM API（需 GOOGLE_CLOUD_* 变量，已在上方配置）
# Consumer 模式：OAuth2 用户访问令牌
NOTEBOOKLM_ACCESS_TOKEN=ya29.your_access_token_here
NOTEBOOKLM_REFRESH_TOKEN=1//0your_refresh_token_here

# ===== OneEval 评测框架配置（北大DCAI团队）=====
# https://github.com/OpenDCAI/One-Eval
# https://arxiv.org/abs/2603.09821
#
# Python 环境路径（留空则自动检测 conda one-eval 环境）
PYTHON_PATH=/path/to/conda/envs/one-eval/bin/python
#
# HTTP 模式：OneEval Server 地址（留空则使用 subprocess 模式）
# 启动 OneEval Server: uvicorn one_eval.server.app:app --host 0.0.0.0 --port 8000
ONEVAL_SERVER_URL=http://localhost:8000

# ===== OpenSpace 知识库配置 =====
OPENSPACE_DATA_DIR=./data/openspace
KNOWLEDGE_BASE_ENABLED=true

# ===== Redis 配置（任务队列）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 数字永生存储配置 =====
IMMORTAL_DB_PATH=./data/immortal
BRAND_FACTS_PATH=./data/brand-facts.json
PAYMENT_DATA_DIR=./data/payments

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== 端口配置 =====
PORT=3000
WS_PORT=3001

# ===== Heartbeat 配置 =====
HEARTBEAT_INTERVAL_MS=5000
HEARTBEAT_FAILURE_THRESHOLD=3
HEARTBEAT_MAX_FAILURES=10

# ===== 蜂巢协作配置 =====
HONEYCOMB_ENABLED=true
OPC_PROTOCOL_VERSION=1.0
