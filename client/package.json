{
  "name": "simiaiclaw-client",
  "version": "1.0.0",
  "private": true,
  "description": "🦞 SIMIAICLAW 龙虾集群控制台 - 多平台AI智能体管理",
  "main": "dist-electron/main.js",
  "author": "SIMIAICLAW Team",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node postbuild.js",
    "build:web": "npm run build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder",
    "electron:dev": "npm run build && tsc -p electron/tsconfig.json && electron .",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run cap:sync && cap open ios",
    "cap:android": "npm run cap:sync && cap open android",
    "build:ios": "npm run cap:sync",
    "build:android": "npm run cap:sync",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "build:mac": "npm run electron:build -- --mac",
    "build:win": "npm run electron:build -- --win",
    "build:linux": "npm run electron:build -- --linux",
    "build:linux:x64": "npm run electron:build -- --linux x64",
    "build:linux:arm64": "npm run electron:build -- --linux arm64",
    "build:linux:dir": "npm run electron:build -- --linux dir",
    "build:all": "npm run electron:build -- --mac --win --linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@tanstack/react-query": "^5.17.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  },
  "build": {
    "appId": "com.simiaiclaw.lobster",
    "productName": "龙虾集群控制台",
    "copyright": "Copyright © 2026 SIMIAICLAW",
    "directories": {
      "output": "release",
      "buildResources": "electron/assets"
    },
    "files": [
      "dist/client/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/assets/entitlements.plist",
      "entitlementsInherit": "electron/assets/entitlements.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/assets/icon.ico",
      "publisherName": "SIMIAICLAW"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb",      "arch": ["x64", "arm64"] },
        { "target": "tar.gz",  "arch": ["x64", "arm64"] }
      ],
      "icon": "electron/assets",
      "category": "Development",
      "desktop": {
        "Name": "龙虾集群控制台",
        "Comment": "SIMIAICLAW 龙虾集群太极64卦系统 - AI智能体协同工作台",
        "Keywords": "AI;智能体;Electron;多平台;MCP",
        "StartupWMClass": "龙虾集群控制台"
      },
      "executableName": "simiaiclaw-client",
      "maintainer": "SIMIAICLAW Team <support@simiaiclaw.com>",
      "vendor": "SIMIAICLAW"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeaderIcon": "electron/assets/icon.ico"
    }
  }
}
